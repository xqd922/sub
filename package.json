{
  "name": "sub",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "concurrently -n web,worker -c blue,green \"bun run dev:web\" \"bun run dev:worker\"",
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "build": "bun run build:web && bun run build:worker",
    "build:web": "vite build",
    "build:worker": "wrangler deploy --dry-run --outdir=dist/worker",
    "deploy": "bun run build:web && wrangler deploy",
    "preview": "bun run build && wrangler dev --local",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "kv:create": "wrangler kv namespace create LINKS_KV"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.14",
    "country-emoji": "^1.5.6",
    "hono": "^4.6.14",
    "js-yaml": "^4.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251225.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "wrangler": "^4.59.2"
  }
}
