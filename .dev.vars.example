# Local-only secrets used by `wrangler dev` (loaded automatically).
# Copy to `.dev.vars` and fill in. NEVER commit `.dev.vars`.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_TOKEN=
SITE_URL=http://localhost:8787

# Short-link providers (all optional — at least one must be configured for /api/shorten).
SINK_URL=
SINK_TOKEN=
BITLY_TOKEN=
CUTTLY_TOKEN=
